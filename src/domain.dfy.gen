      var task := (if tid in taskData then Some(taskData[tid]) else None);
      match task {
        case Some(i_task_val) =>
          if (!(i_task_val.deleted) && eqIgnoreCase(i_task_val.title, title)) then
            true
          else
            taskTitleExistsFrom(lane, taskData, title, excludeTask, (i + 1))
        case None =>
          taskTitleExistsFrom(lane, taskData, title, excludeTask, (i + 1))
      }
    else
      taskTitleExistsFrom(lane, taskData, title, excludeTask, (i + 1))
}

