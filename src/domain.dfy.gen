function taskTitleExistsFrom(lane: seq<TaskId>, taskData: map<int, Task>, title: string, excludeTask: Option<TaskId>, i: int): bool
  requires (i >= 0)
  requires (i <= |lane|)
  decreases (|lane| - i)
{
