function posFromPlace(lane: seq<TaskId>, p: Place): int
{
  match p {
    case AtEnd =>
      |lane|
    case Before(i_p_anchor) =>
      var idx := SeqIndexOf(lane, i_p_anchor);
      if (idx < 0) then
        -1
      else
        idx
    case _ =>
      var idx := SeqIndexOf(lane, p.anchor);
      if (idx < 0) then
        -1
      else
        (idx + 1)
  }
}

function posFromListPlace(lists: seq<ListId>, p: ListPlace): int
{
  match p {
    case ListAtEnd =>
      |lists|
    case ListBefore(i_p_anchor) =>
      var idx := SeqIndexOf(lists, i_p_anchor);
      if (idx < 0) then
        -1
      else
        idx
    case _ =>
      var idx := SeqIndexOf(lists, p.anchor);
      if (idx < 0) then
        -1
      else
        (idx + 1)
  }
}

function listNameExistsFrom(lists: seq<ListId>, listNames: map<int, string>, name: string, excludeList: Option<ListId>, i: int): bool
