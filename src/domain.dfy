    case RestoreTask(i_a_taskId) =>
      var task := (if i_a_taskId in m.taskData then Some(m.taskData[i_a_taskId]) else None);
      match task {
        case Some(i_task_val) =>
          if !(i_task_val.deleted) then
            err(Err.MissingTask)
          else
