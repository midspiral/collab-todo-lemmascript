        case Some(i_task_val) =>
          if i_task_val.deleted then
            err(Err.TaskDeleted)
          else
            match a.dueDate {
              case Some(i_a_dueDate_val) =>
                if !(validDate(i_a_dueDate_val)) then
                  err(Err.InvalidDate)
                else
                  ok(m.(taskData := m.taskData[i_a_taskId := i_task_val.(dueDate := Some(i_a_dueDate_val))]))
              case None =>
