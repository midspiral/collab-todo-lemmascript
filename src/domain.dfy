  ensures (daysInMonth(month, year) >= 0)
{
}

function validDate(d: DateVal): bool
{
  (((((d.year >= 1970) && (d.month >= 1)) && (d.month <= 12)) && (d.day >= 1)) && (d.day <= daysInMonth(d.month, d.year)))
}

