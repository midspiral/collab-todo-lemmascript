              err(Err.MissingList)
            else
              var targetList := (match i_task_val.deletedFromList { case Some(i__narr1) => i__narr1 case None => m.lists[0] });
              if taskTitleExistsInList(m, targetList, i_task_val.title, None) then
                err(Err.DuplicateTask)
              else
