        ok(m)
      else
        var newTaskData := removeTagFromAllTasks(m.taskData, i_a_tagId);
        var newTags := (map k | k in m.tags && k != i_a_tagId :: m.tags[k]);
        ok(m.(taskData := newTaskData, tags := newTags))
    case MakeCollaborative =>
      if m.mode.Collaborative? then
        ok(m)
      else
        ok(m.(mode := ProjectMode.Collaborative))
    case AddMember(i_a_userId) =>
      if m.mode.Personal? then
        err(Err.PersonalProject)
      else
        if (i_a_userId in m.members) then
          ok(m)
        else
          ok(m.(members := (m.members + [i_a_userId])))
    case RemoveMember(i_a_userId) =>
      if (i_a_userId == m.owner) then
        err(Err.CannotRemoveOwner)
      else
        if !((i_a_userId in m.members)) then
          ok(m)
        else
          var newTaskData := clearAssigneeFromAllTasks(m.taskData, i_a_userId);
          ok(m.(members := Std.Collections.Seq.Filter((u: string) => (u != a.userId), m.members), taskData := newTaskData))
  }
}

function degradeIfAnchorMoved(movedId: TaskId, p: Place): Place
{
  match p {
    case AtEnd =>
      p
    case Before(i_p_anchor) =>
      if (i_p_anchor == movedId) then
        Place.AtEnd
      else
        p
    case _ =>
      if (p.anchor == movedId) then
        Place.AtEnd
      else
        p
  }
}

function rebaseAgainstDelete(remoteTaskId: TaskId, local: Action): Action
{
  match local {
    case EditTask(i_local_taskId, i_local_title, i_local_notes) =>
      if (i_local_taskId == remoteTaskId) then
        Action.NoOp
      else
        local
    case MoveTask(i_local_taskId, i_local_toList, i_local_taskPlace) =>
      if (i_local_taskId == remoteTaskId) then
        Action.NoOp
      else
        local
    case CompleteTask(i_local_taskId) =>
      if (i_local_taskId == remoteTaskId) then
        Action.NoOp
      else
        local
    case UncompleteTask(i_local_taskId) =>
      if (i_local_taskId == remoteTaskId) then
        Action.NoOp
      else
        local
    case StarTask(i_local_taskId) =>
      if (i_local_taskId == remoteTaskId) then
        Action.NoOp
      else
        local
    case UnstarTask(i_local_taskId) =>
      if (i_local_taskId == remoteTaskId) then
        Action.NoOp
      else
        local
    case SetDueDate(i_local_taskId, i_local_dueDate) =>
      if (i_local_taskId == remoteTaskId) then
        Action.NoOp
      else
        local
    case AssignTask(i_local_taskId, i_local_userId) =>
      if (i_local_taskId == remoteTaskId) then
        Action.NoOp
      else
        local
    case UnassignTask(i_local_taskId, i_local_userId) =>
      if (i_local_taskId == remoteTaskId) then
        Action.NoOp
      else
        local
    case AddTagToTask(i_local_taskId, i_local_tagId) =>
      if (i_local_taskId == remoteTaskId) then
        Action.NoOp
      else
        local
    case RemoveTagFromTask(i_local_taskId, i_local_tagId) =>
      if (i_local_taskId == remoteTaskId) then
        Action.NoOp
      else
        local
    case _ =>
      local
  }
}

function rebaseOther(remote: Action, local: Action): Action
{
  if (remote.RemoveMember? && local.AssignTask?) then
    if (remote.userId == local.userId) then
      Action.NoOp
    else
      local
  else
    if (remote.MoveList? && local.MoveList?) then
      if (remote.listId == local.listId) then
        Action.NoOp
      else
        local
    else
      if (remote.MoveTask? && local.MoveTask?) then
        if (remote.taskId == local.taskId) then
          local
        else
          MoveTask(local.taskId, local.toList, degradeIfAnchorMoved(remote.taskId, local.taskPlace))
      else
        local
}

function rebase(remote: Action, local: Action): Action
{
  match remote {
    case NoOp =>
      local
    case _ =>
      match local {
        case NoOp =>
          local
        case _ =>
          match remote {
            case DeleteTask(i_remote_taskId, i_remote_userId) =>
              rebaseAgainstDelete(i_remote_taskId, local)
            case _ =>
              rebaseOther(remote, local)
          }
      }
  }
}

function candidates(i_m: int, a: Action): seq<Action>
{
  if (a.MoveTask? && (!a.taskPlace.AtEnd?)) then
    [a, a.(taskPlace := Place.AtEnd)]
  else
    if (a.MoveList? && (!a.listPlace.ListAtEnd?)) then
      [a, a.(listPlace := ListPlace.ListAtEnd)]
    else
      [a]
}

function isPriorityTask(t: Task): bool
{
  ((t.starred && !(t.completed)) && !(t.deleted))
}

function isLogbookTask(t: Task): bool
{
  (t.completed && !(t.deleted))
}

function isVisibleTask(t: Task): bool
{
  !(t.deleted)
}

function getTask(m: Model, taskId: TaskId): Option<Task>
{
  var t := (if taskId in m.taskData then Some(m.taskData[taskId]) else None);
  match t {
    case Some(i_t_val) =>
      if i_t_val.deleted then
        None
      else
        Some(i_t_val)
    case None =>
      None
  }
}

function getTaskIncludingDeleted(m: Model, taskId: TaskId): Option<Task>
{
  (if taskId in m.taskData then Some(m.taskData[taskId]) else None)
}

function getTasksInListFrom(lane: seq<TaskId>, taskData: map<int, Task>, i: int): seq<TaskId>
  requires (i >= 0)
  requires (i <= |lane|)
  decreases (|lane| - i)
{
  if (i >= |lane|) then
    []
  else
    var task := (if lane[i] in taskData then Some(taskData[lane[i]]) else None);
    match task {
      case Some(i_task_val) =>
        if !(i_task_val.deleted) then
          ([lane[i]] + getTasksInListFrom(lane, taskData, (i + 1)))
        else
          getTasksInListFrom(lane, taskData, (i + 1))
      case None =>
        getTasksInListFrom(lane, taskData, (i + 1))
    }
}

function getTasksInList(m: Model, listId: ListId): seq<TaskId>
{
  var lane := (if listId in m.tasks then Some(m.tasks[listId]) else None);
  match lane {
    case Some(i_lane_val) =>
      getTasksInListFrom(i_lane_val, m.taskData, 0)
    case None =>
      []
  }
}

lemma getTasksInList_ensures(m: Model, listId: ListId)
  ensures (|getTasksInList(m, listId)| >= 0)
{
}

function getListName(m: Model, listId: ListId): Option<string>
{
  (if listId in m.listNames then Some(m.listNames[listId]) else None)
}

function getLists(m: Model): seq<ListId>
{
  m.lists
}

function getTagName(m: Model, tagId: TagId): Option<string>
{
  var tag := (if tagId in m.tags then Some(m.tags[tagId]) else None);
  match tag {
    case Some(i_tag_val) =>
      Some(i_tag_val.name)
    case None =>
      None
  }
}

const INITIAL_OWNER: string := "__initial__"

function tagNameExists(m: Model, name: string, excludeTag: Option<TagId>): bool
{
  exists tid :: tid in m.tags &&
    (match excludeTag { case None => true case Some(v) => v != tid }) &&
    eqIgnoreCase(m.tags[tid].name, name)
}
by method {
  var i_tid_keys := SetToSeq(m.tags.Keys);
  var i_tid_idx := 0;
  while i_tid_idx < |i_tid_keys|
    invariant (i_tid_idx <= |i_tid_keys|)
    invariant forall j :: 0 <= j < i_tid_idx ==>
      !((match excludeTag { case None => true case Some(v) => v != i_tid_keys[j] }) &&
        eqIgnoreCase(m.tags[i_tid_keys[j]].name, name))
  {
    var tid := i_tid_keys[i_tid_idx];
    var tag := m.tags[tid];
    if ((match excludeTag { case Some(i_) => false case None => true }) || (match excludeTag { case Some(i_value) => (i_value != tid) case None => true })) {
      var i_t0 := eqIgnoreCase(tag.name, name);
      if i_t0 {
        return true;
      }
    }
    i_tid_idx := i_tid_idx + 1;
  }
  return false;
}

function FilterNeqInt(s: seq<int>, v: int): seq<int>
  decreases |s|
{
  if |s| == 0 then []
  else (if s[0] != v then [s[0]] else []) + FilterNeqInt(s[1..], v)
}

lemma FilterNeqIntEquiv(s: seq<int>, v: int)
  ensures Std.Collections.Seq.Filter((t: int) => (t != v), s) == FilterNeqInt(s, v)
  decreases |s|
{
  reveal Std.Collections.Seq.Filter();
  if |s| > 0 {
    FilterNeqIntEquiv(s[1..], v);
  }
}

function FilterNeqString(s: seq<string>, v: string): seq<string>
  decreases |s|
{
  if |s| == 0 then []
  else (if s[0] != v then [s[0]] else []) + FilterNeqString(s[1..], v)
}

lemma FilterNeqStringEquiv(s: seq<string>, v: string)
  ensures Std.Collections.Seq.Filter((u: string) => (u != v), s) == FilterNeqString(s, v)
  decreases |s|
{
  reveal Std.Collections.Seq.Filter();
  if |s| > 0 {
    FilterNeqStringEquiv(s[1..], v);
  }
}

function removeTagFromAllTasks(taskData: map<int, Task>, tagId: TagId): map<int, Task>
{
  map tid | tid in taskData :: taskData[tid].(tags := FilterNeqInt(taskData[tid].tags, tagId))
}
by method {
  var result: map<int, Task> := map[];
  var i_tid_keys := SetToSeq(taskData.Keys);
  var i_tid_idx := 0;
  while i_tid_idx < |i_tid_keys|
    invariant (i_tid_idx <= |i_tid_keys|)
    invariant forall tid :: tid in i_tid_keys[..i_tid_idx] ==> tid in result
    invariant forall tid :: tid in result ==> tid in taskData && result[tid] == taskData[tid].(tags := FilterNeqInt(taskData[tid].tags, tagId))
  {
    var tid := i_tid_keys[i_tid_idx];
    var task := taskData[tid];
    var newTags := Std.Collections.Seq.Filter((t: int) => (t != tagId), task.tags);
    FilterNeqIntEquiv(task.tags, tagId);
    result := result[tid := task.(tags := newTags)];
    i_tid_idx := i_tid_idx + 1;
  }
  assert forall tid :: tid in i_tid_keys <==> tid in taskData;
  assert forall tid :: tid in taskData <==> tid in result by {
    forall tid | tid in taskData ensures tid in result {
      assert tid in i_tid_keys;
    }
  }
  return result;
}

function clearAssigneeFromAllTasks(taskData: map<int, Task>, userId: UserId): map<int, Task>
{
  map tid | tid in taskData :: taskData[tid].(assignees := FilterNeqString(taskData[tid].assignees, userId))
}
by method {
  var result: map<int, Task> := map[];
  var i_tid_keys := SetToSeq(taskData.Keys);
  var i_tid_idx := 0;
  while i_tid_idx < |i_tid_keys|
    invariant (i_tid_idx <= |i_tid_keys|)
    invariant forall tid :: tid in i_tid_keys[..i_tid_idx] ==> tid in result
    invariant forall tid :: tid in result ==> tid in taskData && result[tid] == taskData[tid].(assignees := FilterNeqString(taskData[tid].assignees, userId))
  {
    var tid := i_tid_keys[i_tid_idx];
    var task := taskData[tid];
    var newAssignees := Std.Collections.Seq.Filter((u: string) => (u != userId), task.assignees);
    FilterNeqStringEquiv(task.assignees, userId);
    result := result[tid := task.(assignees := newAssignees)];
    i_tid_idx := i_tid_idx + 1;
  }
  assert forall tid :: tid in i_tid_keys <==> tid in taskData;
  assert forall tid :: tid in taskData <==> tid in result by {
    forall tid | tid in taskData ensures tid in result {
      assert tid in i_tid_keys;
    }
  }
  return result;
}

function countPriorityTasks(m: Model): int
{
  |set tid | tid in m.taskData && isPriorityTask(m.taskData[tid]) :: tid|
}
by method {
  var count := 0;
  var i___keys := SetToSeq(m.taskData.Keys);
  var i___idx := 0;
  ghost var matched: set<int> := {};
  while i___idx < |i___keys|
    invariant (i___idx <= |i___keys|)
    invariant matched == set tid | tid in i___keys[..i___idx] && isPriorityTask(m.taskData[tid]) :: tid
    invariant count == |matched|
  {
    var i_ := i___keys[i___idx];
    var task := m.taskData[i_];
    var i_t1 := isPriorityTask(task);
    if i_t1 {
      count := (count + 1);
      matched := matched + {i_};
    }
    i___idx := i___idx + 1;
  }
  assert forall tid :: tid in i___keys <==> tid in m.taskData;
  assert matched == set tid | tid in m.taskData && isPriorityTask(m.taskData[tid]) :: tid;
  return count;
}

